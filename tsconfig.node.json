{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "outDir": "dist-electron",
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/main/**/*", "electron.vite.config.ts"]
}
